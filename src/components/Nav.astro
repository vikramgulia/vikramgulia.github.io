---
const navLinks = [
  { label: "Home", href: "/#home" },
  { label: "About", href: "/#about" },
  { label: "Projects", href: "/#projects" },
  { label: "Contact", href: "/#contact" },
  { label: "Tools", href: "/tools" },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="font-mono text-2xl font-bold gradient-text tracking-tight">
        VG
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(({ label, href }) => (
          <a
            href={href}
            class="text-sm font-medium text-text-muted hover:text-accent-cyan transition-colors duration-200"
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Mobile Hamburger -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Toggle menu"
      >
        <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg-surface/95 backdrop-blur-md border-t border-border-subtle">
    <div class="px-4 py-4 space-y-2">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="block py-2 text-text-muted hover:text-accent-cyan transition-colors"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  function initNav() {
    const nav = document.getElementById("main-nav");
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        nav?.classList.add("bg-bg-deep/90", "backdrop-blur-md", "shadow-lg");
      } else {
        nav?.classList.remove("bg-bg-deep/90", "backdrop-blur-md", "shadow-lg");
      }
    });

    mobileBtn?.addEventListener("click", () => {
      const isOpen = !mobileMenu?.classList.contains("hidden");
      mobileMenu?.classList.toggle("hidden");
      const lines = mobileBtn.querySelectorAll(".hamburger-line");
      if (!isOpen) {
        lines[0]?.classList.add("rotate-45", "translate-y-2");
        lines[1]?.classList.add("opacity-0");
        lines[2]?.classList.add("-rotate-45", "-translate-y-2");
      } else {
        lines[0]?.classList.remove("rotate-45", "translate-y-2");
        lines[1]?.classList.remove("opacity-0");
        lines[2]?.classList.remove("-rotate-45", "-translate-y-2");
      }
    });

    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
        const lines = mobileBtn?.querySelectorAll(".hamburger-line");
        lines?.[0]?.classList.remove("rotate-45", "translate-y-2");
        lines?.[1]?.classList.remove("opacity-0");
        lines?.[2]?.classList.remove("-rotate-45", "-translate-y-2");
      });
    });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>
