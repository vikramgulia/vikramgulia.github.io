---
import projectsData from "../data/projects.json";

interface GitHubRepo {
  name: string;
  full_name: string;
  html_url: string;
  description: string | null;
  language: string | null;
  stargazers_count: number;
  forks_count: number;
  topics: string[];
}

interface ProjectEntry {
  repo: string;
  featured: boolean;
  description_override?: string;
}

const languageColors: Record<string, string> = {
  TypeScript: "#3178c6",
  JavaScript: "#f1e05a",
  Python: "#3572A5",
  Go: "#00ADD8",
  Rust: "#dea584",
  Java: "#b07219",
  "C#": "#178600",
  HTML: "#e34c26",
  CSS: "#563d7c",
  Shell: "#89e051",
  Astro: "#ff5a03",
};

const projects: {
  name: string;
  full_name: string;
  url: string;
  description: string;
  language: string | null;
  stars: number;
  forks: number;
  topics: string[];
}[] = [];

for (const entry of projectsData as ProjectEntry[]) {
  try {
    const res = await fetch(`https://api.github.com/repos/${entry.repo}`);
    if (res.ok) {
      const data: GitHubRepo = await res.json();
      projects.push({
        name: data.name,
        full_name: data.full_name,
        url: data.html_url,
        description: entry.description_override || data.description || "No description available.",
        language: data.language,
        stars: data.stargazers_count,
        forks: data.forks_count,
        topics: data.topics || [],
      });
    } else {
      projects.push({
        name: entry.repo.split("/")[1],
        full_name: entry.repo,
        url: `https://github.com/${entry.repo}`,
        description: entry.description_override || "No description available.",
        language: null,
        stars: 0,
        forks: 0,
        topics: [],
      });
    }
  } catch {
    projects.push({
      name: entry.repo.split("/")[1],
      full_name: entry.repo,
      url: `https://github.com/${entry.repo}`,
      description: entry.description_override || "No description available.",
      language: null,
      stars: 0,
      forks: 0,
      topics: [],
    });
  }
}
---

<section id="projects" class="py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold font-mono mb-3">
        <span class="text-accent-cyan font-normal text-lg block mb-2 font-mono">// projects</span>
        Featured Projects
      </h2>
      <div class="w-20 h-0.5 bg-gradient-to-r from-accent-cyan to-accent-violet mx-auto mb-4"></div>
      <p class="text-text-muted max-w-lg mx-auto">
        Open source work and side projects.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group card-base glow-border hover:glow-border-hover transition-all duration-300 flex flex-col"
        >
          <div class="flex items-start justify-between mb-3">
            <svg class="w-8 h-8 text-text-dim group-hover:text-accent-cyan transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
            <svg class="w-4 h-4 text-text-dim group-hover:text-accent-cyan transition-colors opacity-0 group-hover:opacity-100 -translate-y-1 group-hover:translate-y-0 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7"/>
              <path d="M7 7h10v10"/>
            </svg>
          </div>

          <h3 class="font-mono font-semibold text-text-primary group-hover:text-accent-cyan transition-colors mb-2">
            {project.name}
          </h3>

          <p class="text-sm text-text-muted leading-relaxed flex-grow mb-4">
            {project.description}
          </p>

          <div class="flex items-center gap-4 text-xs text-text-dim mt-auto pt-3 border-t border-border-subtle">
            {project.language && (
              <span class="flex items-center gap-1.5">
                <span
                  class="w-3 h-3 rounded-full inline-block"
                  style={`background-color: ${languageColors[project.language] || "#6e7681"}`}
                />
                {project.language}
              </span>
            )}
            {project.stars > 0 && (
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                {project.stars}
              </span>
            )}
            {project.forks > 0 && (
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="18" r="3"/>
                  <circle cx="6" cy="6" r="3"/>
                  <circle cx="18" cy="6" r="3"/>
                  <path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9"/>
                  <path d="M12 12v3"/>
                </svg>
                {project.forks}
              </span>
            )}
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="https://github.com/vikramgulia?tab=repositories"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-mono text-sm glow-border hover:glow-border-hover text-text-muted hover:text-accent-cyan transition-all duration-300"
      >
        View all repositories
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7"/>
          <path d="M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </div>
</section>
