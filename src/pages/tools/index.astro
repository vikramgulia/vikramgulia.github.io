---
import BaseLayout from "../../layouts/BaseLayout.astro";

const tools = [
  {
    name: "Storage Calculator",
    description: "Estimate total objects and storage needed for your system design calculations.",
    href: "/tools/calculator",
    icon: "database",
  },
];
---

<BaseLayout title="Tools — Vikram Gulia">
  <section class="pt-28 pb-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-text-dim hover:text-accent-cyan transition-colors mb-6 font-mono">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
          </svg>
          Back to home
        </a>
        <h1 class="text-3xl sm:text-4xl font-bold font-mono mb-3">
          <span class="text-accent-cyan font-normal text-lg block mb-2 font-mono">// tools</span>
          Toolbox
        </h1>
        <div class="w-20 h-0.5 bg-gradient-to-r from-accent-cyan to-accent-violet mx-auto mb-4"></div>
        <p class="text-text-muted max-w-md mx-auto">
          Handy utilities for back-of-the-envelope engineering calculations and more.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {tools.map((tool) => (
          <a
            href={tool.href}
            class="group card-base glow-border hover:glow-border-hover transition-all duration-300 flex flex-col"
          >
            <div class="flex items-start justify-between mb-4">
              <div class="p-3 rounded-lg bg-bg-deep border border-border-subtle group-hover:border-accent-cyan/30 transition-colors">
                <svg class="w-6 h-6 text-accent-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <ellipse cx="12" cy="5" rx="9" ry="3"/>
                  <path d="M3 5V19A9 3 0 0 0 21 19V5"/>
                  <path d="M3 12A9 3 0 0 0 21 12"/>
                </svg>
              </div>
              <svg class="w-4 h-4 text-text-dim group-hover:text-accent-cyan transition-all opacity-0 group-hover:opacity-100 -translate-y-1 group-hover:translate-y-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7"/>
                <path d="M7 7h10v10"/>
              </svg>
            </div>

            <h2 class="font-mono font-semibold text-text-primary group-hover:text-accent-cyan transition-colors mb-2">
              {tool.name}
            </h2>

            <p class="text-sm text-text-muted leading-relaxed">
              {tool.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
